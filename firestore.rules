rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only authenticated users can read/write
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    match /admin_tokens/{docId} {
      allow read, write: if request.auth != null;
    }
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }
  }
}
